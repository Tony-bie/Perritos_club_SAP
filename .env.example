SAP_SOC_BASE_URL=http://localhost:8000
SAP_SOC_TOKEN=your-token
SAP_SOC_TIMEOUT_SECONDS=30
SAP_SOC_OUTPUT_DIR=data
SAP_SOC_POLL_SECONDS=1800
SAP_SOC_ALERT_THRESHOLD=40
SAP_SOC_TRAINING_MIN_ROWS=24
SAP_SOC_TRAINING_CONTAMINATION=0.1

# Optional SAP HANA persistence
# If these are empty, the app will also try Cloud Foundry VCAP_SERVICES automatically.
SAP_HANA_HOST=
SAP_HANA_PORT=443
SAP_HANA_USER=
SAP_HANA_PASSWORD=
SAP_HANA_SCHEMA=SOC_PIPELINE
SAP_HANA_ENCRYPT=true
SAP_HANA_VALIDATE_CERTIFICATE=false
SAP_HANA_SERVICE_NAME=
