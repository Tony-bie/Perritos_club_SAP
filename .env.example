# SAP SOC API
SAP_SOC_BASE_URL=https://sap-api-b3.678314.xyz
SAP_SOC_TOKEN=replace-with-your-token

# Runtime
APP_HOST=0.0.0.0
APP_PORT=8000
ENABLE_WORKER=false
POLL_INTERVAL_MINUTES=30
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=2

# Storage backend: sqlite or hana
STORAGE_BACKEND=sqlite
SQLITE_PATH=./pipeline.db

# SAP HANA
# In Cloud Foundry, host/port/TLS can be auto-read from a hana-cloud VCAP_SERVICES binding.
# Set HANA_USER/HANA_PASSWORD explicitly if your binding does not expose database credentials.
# When running in Cloud Foundry, VCAP service credentials take precedence over HANA_* env vars.
HANA_HOST=your-hana-host
HANA_PORT=443
HANA_USER=your-user
HANA_PASSWORD=your-password
HANA_SCHEMA=SOC_PIPELINE
HANA_ENCRYPT=true
HANA_VALIDATE_CERTIFICATE=false

# Detection thresholds
ERROR_SECURITY_THRESHOLD=25
ATTACK_SCORE_THRESHOLD=40

# Anomaly model
MODEL_ENABLED=true
# Options: isolation_forest, kmeans, hybrid
MODEL_ALGORITHM=isolation_forest
MODEL_MIN_TRAINING_ROWS=12
MODEL_CONTAMINATION=0.15
MODEL_KMEANS_CLUSTERS=4
MODEL_HISTORY_LIMIT=200

# Bloque B: Optimization & Retention (Batch upserts, cleanup policies)
# Batch size for bulk inserts (upserts in HANA use executemany)
BATCH_SIZE=1000
# Data retention policy: keep data for N days, older records are deleted
RETENTION_DAYS=90
# Enable automatic cleanup scheduling (via background job or external scheduler)
CLEANUP_SCHEDULE_ENABLED=true
# Hour to run cleanup job (0-23, UTC) — default 02:00 AM
CLEANUP_SCHEDULE_HOUR=2
