# Copy this file to .env when you want to run against SAP HANA Cloud.

SAP_SOC_BASE_URL=https://your-sap-soc-api.example.com
SAP_SOC_TOKEN=replace-with-your-api-token
SAP_SOC_TIMEOUT_SECONDS=30
SAP_SOC_OUTPUT_DIR=data
SAP_SOC_POLL_SECONDS=1800
SAP_SOC_ALERT_THRESHOLD=40
SAP_SOC_TRAINING_MIN_ROWS=24
SAP_SOC_TRAINING_CONTAMINATION=0.1

# SAP HANA Cloud connection
SAP_HANA_HOST=your-instance-id.hana.prod-region.hanacloud.ondemand.com
SAP_HANA_PORT=443
SAP_HANA_USER=DBADMIN
SAP_HANA_PASSWORD=replace-with-your-password
SAP_HANA_SCHEMA=SOC_PIPELINE
SAP_HANA_ENCRYPT=true
SAP_HANA_VALIDATE_CERTIFICATE=false
SAP_HANA_SERVICE_NAME=
